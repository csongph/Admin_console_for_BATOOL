# PostgreSQL connection string
# Local:  postgresql+asyncpg://postgres:PASSWORD@localhost:5432/ba_tool
# Render: ใส่ค่าจาก dashboard (จะถูก inject อัตโนมัติถ้าใช้ render.yaml)
DATABASE_URL=postgresql+asyncpg://postgres:131047@localhost:5432/sql_converter-multiple_database

# สร้างด้วย: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ec8473bf23349244d80b46fd18a3b70634796222f05c737fa1651f77c4a788c1

# JWT token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# "development" หรือ "production"
ENVIRONMENT=development

# Port สำหรับ server (Render inject อัตโนมัติ)
PORT=8000

# Admin credentials — เปลี่ยน password ก่อน deploy
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin131047
